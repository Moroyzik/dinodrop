ENV=development
PROVIDERS_MODE=mock

SECRET_KEY=mock_secret_key

DATABASE_URL=postgresql+psycopg2://app:app@postgres:5432/app
REDIS_URL=redis://redis:6379/0

# Steam
STEAM_API_KEY=mock_steam_key
STEAM_OPENID_RETURN=http://localhost/auth/steam/callback

# YooKassa
YOOKASSA_SHOP_ID=mock_shop_id
YOOKASSA_SECRET=mock_secret
YOOKASSA_PAYOUT_KEY=mock_payout

# USDT provider (sandbox/mock)
USDT_PROVIDER_KEY=mock_usdt_key
USDT_TRON_WALLET=TR_mock_wallet
USDT_ETH_WALLET=0xmockwallet

# SMTP / Sentry (no-op)
SMTP_HOST=mock_smtp
SMTP_USER=mock_user
SMTP_PASS=mock_pass
SENTRY_DSN=mock_sentry

